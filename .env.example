# NutrIAssistant Environment Variables — copy to .env and fill in real values

# BFF base URL. Safe to ship in the bundle — it is just a public URL.
# All API secrets are kept server-side in the Cloudflare Worker.
EXPO_PUBLIC_BFF_BASE_URL=https://api.nutriassistant.org

# Legacy API keys: kept ONLY for clients that still call upstream directly.
# Phase 2 of the BFF migration removes them from the bundle entirely.
EXPO_PUBLIC_SPOONACULAR_API_KEY=your_spoonacular_api_key

# Edamam credentials live ONLY in Cloudflare's secret store (set via
# `wrangler secret put` from infra/bff/). They do NOT belong in this file
# beyond local development; if you do need them locally for dev tooling,
# add EDAMAM_APP_ID and EDAMAM_APP_KEY (no EXPO_PUBLIC_ prefix) so they
# never make it into the bundle.
