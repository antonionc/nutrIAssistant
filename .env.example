# NutrIAssistant Environment Variables — copy to .env and fill in real values

# BFF base URL. Safe to ship in the bundle — it is just a public URL.
# All third-party API secrets (Spoonacular API key, Edamam app_id/app_key)
# live server-side in the Cloudflare Worker and are NEVER required in
# this file. To override the BFF location during local development,
# point this at `http://localhost:8787` while `wrangler dev` is running.
EXPO_PUBLIC_BFF_BASE_URL=https://api.nutriassistant.org
